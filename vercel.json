{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/$1"
    }
  ],
  "redirects": [
    {
      "source": "/backend",
      "destination": "/",
      "permanent": false
    }
  ]
}
